# Backend Environment Variables
PORT=5500
MONGO_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/?appName=yourApp
JWT_SECRET=your_super_secret_key
GEMINI_API_KEY=your_gemini_api_key

# Email (for OTP)
EMAIL=your_email@gmail.com
PASSWORD=your_app_password

# AWS S3 Configuration
AWS_ACCESS_KEY=your_aws_access_key
AWS_SECRET=your_aws_secret_key
AWS_BUCKET_NAME=your-bucket-name
AWS_REGION=eu-north-1

# CORS - comma-separated allowed origins (use * for development)
# For production, set to your frontend URL e.g.: https://your-app.vercel.app
CORS_ORIGIN=*
